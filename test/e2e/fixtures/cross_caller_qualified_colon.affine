//
// #178 INT-01 follow-up: `use Mod;` + qualified *value* call via the
// `::` separator: `Mod::fn(x)`.  Parser lowers it to the same
// ExprField(ExprVar Mod, fn) shape the `.` form produces, so
// Resolve.lower_qualified_value_paths handles both syntaxes
// identically (canonical `::`-fold; no resolver change).

use CrossCallee;

pub fn main() -> Int {
  return CrossCallee::consume(42);
}
