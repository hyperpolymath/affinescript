//
// Caller that calls the Linear-param import on one branch only — silently
// drops the linear argument on the zero-call branch. Verify-boundary must
// report LinearImportDroppedOnSomePath.

use CrossCallee::{consume};

pub fn pick(flag: Int) -> Int {
  if flag > 0 {
    return consume(42);
  } else {
    return 0;
  }
}
