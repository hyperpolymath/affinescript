//
// issue-draft 08 — conditional-origin borrow escape. A borrow bound through an
// `if` (both branches return a borrow of `a`) must keep `a` borrowed, so the
// later move of `a` while `r` is live is a use-after-move. Pre-fix the branch
// block swallowed the escaping borrow and the move slipped past.
fn pick(ref x: Int) -> ref Int { return &x; }
fn consume(own v: Int) -> Int { return v; }

fn main() -> Int {
  let a: Int = 7;
  let c: Bool = true;
  let r = if c { pick(a) } else { pick(a) };
  let _g = consume(a);
  return *r;
}
