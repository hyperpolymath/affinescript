//
// issue-draft 08 anti-over-rejection — the conditional borrows `a`/`b`; moving
// an UNRELATED owned value `d` must stay legal (the union of origins is {a,b},
// not everything).
fn pick(ref x: Int) -> ref Int { return &x; }
fn consume(own v: Int) -> Int { return v; }

fn main() -> Int {
  let a: Int = 7;
  let b: Int = 9;
  let d: Int = 5;
  let c: Bool = true;
  let r = if c { pick(a) } else { pick(b) };
  let _g = consume(d);
  return *r;
}
