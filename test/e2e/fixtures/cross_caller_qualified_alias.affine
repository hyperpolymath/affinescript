// #178 INT-01: aliased qualifier — `use CrossCallee as CC;` + `CC.consume(x)`.
// The alias is the bound qualifier (import_qualifiers prefers the alias).

use CrossCallee as CC;

pub fn main() -> Int {
  return CC.consume(7);
}
