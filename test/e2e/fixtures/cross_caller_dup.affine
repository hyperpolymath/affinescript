//
// Caller that calls the Linear-param import twice on the same path —
// duplicates the linear argument. Verify-boundary must report
// LinearImportCalledMultiple.

use CrossCallee::{consume};

pub fn main() -> Int {
  let a = consume(1);
  let b = consume(2);
  return a + b;
}
