//
// Canonical face — the AffineScript reference syntax. All other faces in
// this directory lower to this same shape via their respective transformers.
// face: canonical

effect IO {
  fn println(s: String) -> ();
}

fn main() -{IO}-> () {
  let greeting = "Hello, AffineScript!";
  println(greeting);
}
