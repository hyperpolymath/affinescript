//
// PHASE-F string-wall slice 3: string_sub — the runtime-length copy op
// (proposals/MIGRATION-PLAN.adoc §"The two walls"). string_sub(s, start,
// length) returns the clamped substring via a runtime-sized heap allocation
// and a byte-copy loop. Read back through the slice-1 reader
// string_char_code_at and string_length.
//
// The companion harness test_string_sub.mjs asserts main() against the value
// derived from the interp oracle (lib/interp.ml string_sub clamps:
// start' = max 0 (min start slen); length' = max 0 (min length (slen-start'))).
// The same constants are pinned interp-side in test/test_e2e.ml
// (E2E String-wall slice 3).

fn main() -> Int {
  // "hello" -> sub(1,3) = "ell"; byte 0 = 'e' (101), byte 2 = 'l' (108)
  let e = string_char_code_at(string_sub("hello", 1, 3), 0);    // 101
  let l = string_char_code_at(string_sub("hello", 1, 3), 2);    // 108
  // negative start clamps to 0: sub(-1,2) = "he"; byte 0 = 'h' (104)
  let h = string_char_code_at(string_sub("hello", -1, 2), 0);   // 104
  // length clamps
  let lenfull = string_length(string_sub("hello", 0, 5));       // 5  (whole string)
  let lenclamp = string_length(string_sub("hello", 2, 100));    // 3  (length clamped to slen-start')
  let lenstart = string_length(string_sub("hello", 10, 3));     // 0  (start clamped to slen)
  let lenzero = string_length(string_sub("hello", 1, 0));       // 0  (zero length)

  // Positional pack of three round-tripped bytes (each 0..255) + the four
  // length probes as an additive checksum:
  //   packed = 101 + 108*256 + 104*65536 = 6843493
  //   + 5 + 3 + 0 + 0                     = +8
  //   total                               = 6843501
  let packed = e + l * 256 + h * 65536;
  packed + lenfull + lenclamp + lenstart + lenzero
}
